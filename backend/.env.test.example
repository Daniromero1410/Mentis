# =============================================================================
# CONFIGURACION DE PRUEBAS AUTOMATIZADAS — BACKEND (pytest)
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.test.example .env.test
#   2. Completa los valores con credenciales reales
#   3. NUNCA subas .env.test a GitHub — ya está en .gitignore
# =============================================================================

# URL del backend en produccion
TEST_API_URL=https://mentis-production.up.railway.app

# Usuario administrador del sistema (rol=admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Usuario con acceso completo a todos los módulos (rol=psicologo o terapeuta)
TEST_EMAIL=
TEST_PASSWORD=

# Segundo usuario (para pruebas de aislamiento cross-user — opcional)
# Si se deja vacío, esas pruebas se saltarán automáticamente
TEST_EMAIL_2=
TEST_PASSWORD_2=
